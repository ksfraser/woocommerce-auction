{
    "name": "yith/auctions-for-woocommerce",
    "description": "YITH Auctions for WooCommerce plugin",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "ksfraser/mock-wordpress": "^1.0",
        "ksfraser/mock-woocommerce": "^1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../mock-wordpress"
        },
        {
            "type": "path",
            "url": "../../mock-woocommerce"
        },
        {
            "type": "path",
            "url": "../../test-factories"
        }
    ],
    "autoload": {
        "psr-4": {
            "YITH\\Auctions\\": "src/",
            "ksfraser\\": "src/ksfraser/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YITH\\Auctions\\Tests\\": "tests/",
            "ksfraser\\": "tests/ksfraser/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
