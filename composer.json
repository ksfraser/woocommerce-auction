{
    "name": "ksfraser/woocommerce-auction",
    "description": "WooCommerce Auction plugin - forked from YITH Auctions for WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=7.3",
        "defuse/php-encryption": "^2.4",
        "ksfraser/html": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "ksfraser/mock-wordpress": "@dev",
        "ksfraser/mock-woocommerce": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../html"
        },
        {
            "type": "path",
            "url": "../../mock-wordpress"
        },
        {
            "type": "path",
            "url": "../../mock-woocommerce"
        },
        {
            "type": "path",
            "url": "../../test-factories"
        }
    ],
    "autoload": {
        "psr-4": {
            "WC\\Auction\\": ["src/", "includes/"],
            "ksfraser\\": "src/ksfraser/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WC\\Auction\\Tests\\": "tests/",
            "ksfraser\\": "tests/ksfraser/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
