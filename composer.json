{
    "name": "yith/auctions-for-woocommerce",
    "description": "YITH Auctions for WooCommerce plugin",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "YITH\\Auctions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YITH\\Auctions\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
